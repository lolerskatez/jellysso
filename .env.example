# JellySSO Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# NOTE: Jellyfin server URL, API key, and admin user are configured
# through the setup wizard on first run (/setup), not via env vars.
# They are stored persistently in the config Docker volume.


# ─── Required secrets ─────────────────────────────────────────────────────────
# Generate each value with: openssl rand -hex 32

SESSION_SECRET=
SHARED_SECRET=
COOKIE_SECRET=


# ─── Optional ─────────────────────────────────────────────────────────────────

# Port the container is published on the host (default: 3010)
APP_PORT=3010

# Log verbosity: error | warn | info | debug (default: info)
LOG_LEVEL=info

# Public-facing URL of JellySSO — required behind a reverse proxy or custom domain
# Used in SSO callbacks, QuickConnect links, and the Jellyfin plugin config
# PUBLIC_URL=https://sso.example.com


# ─── OIDC SSO (optional) ──────────────────────────────────────────────────────
# Set ENABLE_OIDC=true and fill in the values below to enable OIDC login.

ENABLE_OIDC=false

# OIDC_ISSUER_URL=https://auth.example.com
# OIDC_CLIENT_ID=jellysso
# OIDC_CLIENT_SECRET=
# EXTERNAL_OIDC_CLIENTS=