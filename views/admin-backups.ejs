<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Backups - Jellyfin Companion Admin">
  <meta name="csrf-token" content="<%= csrfToken || '' %>">
  <title>Backups - Jellyfin Companion</title>
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/fontawesome.css">
  <style>
    .sidebar-header h2 {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
    }

    .sidebar-header h2 i {
      color: var(--primary);
      font-size: 1.5rem;
    }

    .page-section {
      margin-bottom: var(--spacing-xl);
    }

    .page-section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: var(--spacing-lg);
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
      padding-bottom: var(--spacing-md);
      border-bottom: 2px solid var(--border-color);
    }

    .page-section-title i {
      color: var(--primary);
      font-size: 1.5rem;
    }

    .backup-item {
      background: white;
      border-radius: var(--border-radius);
      padding: var(--spacing-lg);
      border: 1px solid var(--border-color);
      box-shadow: var(--shadow-sm);
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--spacing-md);
    }

    .backup-info {
      flex: 1;
    }

    .backup-name {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: var(--spacing-xs);
    }

    .backup-details {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .backup-actions {
      display: flex;
      gap: var(--spacing-sm);
    }

    /* Button styles */
    .backup-action-btn {
      padding: 8px 14px;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.8125rem;
      transition: all 0.2s;
      font-weight: 500;
    }

    .backup-btn-success {
      background-color: var(--success);
    }

    .backup-btn-success:hover {
      background-color: #10b981;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
    }

    .backup-btn-warning {
      background-color: var(--warning);
    }

    .backup-btn-warning:hover {
      background-color: #d97706;
      box-shadow: 0 2px 8px rgba(217, 119, 6, 0.3);
    }

    .backup-btn-danger {
      background-color: var(--danger);
    }

    .backup-btn-danger:hover {
      background-color: #dc2626;
      box-shadow: 0 2px 8px rgba(220, 38, 38, 0.4);
    }

    .modal-btn-cancel {
      padding: 12px 24px;
      background: #e5e7eb;
      color: #1f2937;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 500;
      font-size: 0.9375rem;
      transition: all 0.2s;
    }

    .modal-btn-cancel:hover {
      background: #d1d5db;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .modal-btn-primary {
      padding: 12px 24px;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 600;
      font-size: 0.9375rem;
      transition: all 0.2s;
    }

    .modal-btn-warning {
      background: var(--warning);
    }

    .modal-btn-warning:hover {
      background: #d97706;
      box-shadow: 0 4px 12px rgba(217, 119, 6, 0.4);
    }

    .modal-btn-danger {
      background: var(--danger);
    }

    .modal-btn-danger:hover {
      background: #dc2626;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    }

    /* Notification */
    .notification {
      position: fixed;
      top: var(--spacing-lg);
      right: var(--spacing-lg);
      padding: var(--spacing-md) var(--spacing-lg);
      border-radius: var(--border-radius);
      box-shadow: var(--shadow-lg);
      z-index: 1001;
      transform: translateX(150%);
      transition: transform 0.3s ease;
      font-weight: 500;
      font-size: 0.9375rem;
    }
    .notification.show {
      transform: translateX(0);
    }
    .notification.success {
      background: var(--success);
      color: white;
    }
    .notification.error {
      background: var(--danger);
      color: white;
    }
  </style>
</head>
<body>
  <div class="app-container">
    <%- include('partials/navigation', { user, currentPage: 'admin-backups' }) %>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="header">
        <div class="header-left">
          <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
            <i class="fas fa-bars"></i>
          </button>
          <h1 class="header-title">Backups</h1>
        </div>
        <div class="header-right">
          <% if (typeof user !== 'undefined' && user) { %>
            <div class="user-info">
              <div class="user-avatar">
                <%= user.Name.charAt(0).toUpperCase() %>
              </div>
              <div>
                <div style="font-weight: 600; font-size: 0.9375rem;"><%= user.Name %></div>
                <div style="font-size: 0.8125rem; color: var(--text-secondary);">
                  🛡️ Administrator
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </header>

      <!-- Page Content -->
      <div class="page-content">
        <% if (typeof user !== 'undefined' && user && user.Policy?.IsAdministrator) { %>
          <!-- Backups Section -->
          <div class="page-section">
            <h3 class="page-section-title">
              <i class="fas fa-database"></i>
              System Backups
            </h3>
            <div style="background: white; border-radius: var(--border-radius); padding: var(--spacing-lg); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
              <!-- What's Being Backed Up Section -->
              <div style="background: linear-gradient(135deg, rgba(0, 102, 204, 0.08) 0%, rgba(0, 102, 204, 0.04) 100%); border-left: 4px solid var(--primary); padding: var(--spacing-lg); border-radius: var(--border-radius); margin-bottom: var(--spacing-lg);">
                <div style="margin-bottom: var(--spacing-md);">
                  <h4 style="margin: 0 0 var(--spacing-md) 0; font-size: 1rem; color: var(--gray-900); display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-database" style="color: var(--primary);"></i>
                    What's Being Backed Up
                  </h4>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-lg);; margin-bottom: var(--spacing-lg); font-size: 0.875rem;">
                  <!-- Included Items -->
                  <div>
                    <div style="color: var(--success); font-weight: 600; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                      <i class="fas fa-check-circle"></i>
                      Included
                    </div>
                    <ul style="margin: 0; padding-left: 20px; color: var(--text-secondary); line-height: 1.8;">
                      <li>SQLite Database</li>
                      <li>Audit Logs</li>
                      <li>User Accounts</li>
                      <li>Provisioning Settings</li>
                      <li>OIDC Configuration</li>
                      <li>System Settings</li>
                      <li>CSRF Tokens</li>
                    </ul>
                  </div>
                  <!-- Excluded Items -->
                  <div>
                    <div style="color: var(--danger); font-weight: 600; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                      <i class="fas fa-times-circle"></i>
                      NOT Included
                    </div>
                    <ul style="margin: 0; padding-left: 20px; color: var(--text-secondary); line-height: 1.8;">
                      <li>Jellyfin Media Libraries</li>
                      <li>Jellyfin Media Metadata</li>
                      <li>Movie/TV Show Files</li>
                      <li>User Media Collections</li>
                      <li>Transcoding Cache</li>
                    </ul>
                  </div>
                </div>
                <div style="background: white; padding: 12px; border-radius: 4px; border-left: 3px solid var(--warning); color: var(--text-secondary); font-size: 0.8125rem;">
                  <i class="fas fa-exclamation-triangle" style="color: var(--warning); margin-right: 6px;"></i>
                  <strong>Note:</strong> Jellyfin media library backups must be performed through Jellyfin's own backup feature.
                </div>
              </div>

              <!-- Automatic Backup Schedule -->
              <div style="background: rgba(16, 185, 129, 0.05); border-left: 3px solid var(--success); padding: var(--spacing-md); border-radius: var(--border-radius); margin-bottom: var(--spacing-lg); color: var(--text-secondary); font-size: 0.875rem;">
                <i class="fas fa-calendar-alt" style="color: var(--success); margin-right: 8px;"></i>
                <strong>Automatic Backup Schedule:</strong> Monthly on day <strong><%= backupConfig?.monthlyDay || 1 %></strong> at <strong><%= backupConfig?.monthlyHour || 4 %>:00 AM</strong>. Retention: <strong><%= backupConfig?.retention || 12 %> months</strong>. <a href="/admin/settings" style="color: var(--primary);">Configure</a>
              </div>
              <p style="color: var(--text-secondary); margin-top: 0;">
                Create, manage, and restore database backups. You can use the buttons below to create a new backup or import an existing one, or manage your backups below.
              </p>
              <div style="display: flex; gap: var(--spacing-md); margin-top: var(--spacing-lg); flex-wrap: wrap;">
                <button id="createBackupBtn" class="btn btn-primary">
                  <i class="fas fa-plus"></i>
                  Create Backup
                </button>
                <button id="importBackupBtn" class="btn btn-secondary">
                  <i class="fas fa-upload"></i>
                  Import Backup
                </button>
                <input type="file" id="backupFileInput" accept=".db" style="display: none;">
              </div>
              <div id="backupsList" style="margin-top: var(--spacing-lg);">
                <!-- Backups will be loaded here -->
                <p style="color: var(--text-secondary);">Loading backups...</p>
              </div>
            </div>
          </div>

        <% } else { %>
          <!-- Not Authorized -->
          <div class="empty-state" style="padding: 4rem 2rem;">
            <div class="empty-state-icon">
              <i class="fas fa-lock"></i>
            </div>
            <h2 class="empty-state-title">Access Denied</h2>
            <p class="empty-state-text">
              You do not have permission to access the admin backups. Please contact an administrator.
            </p>
            <a href="/" class="btn btn-primary btn-lg">
              <i class="fas fa-home"></i>
              Back to Dashboard
            </a>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <!-- Restore Modal -->
  <div id="restoreModal" class="modal-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; opacity: 0; visibility: hidden; transition: all 0.3s;">
    <div style="background: white; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); width: 100%; max-width: 480px; overflow: hidden; transform: scale(0.9); transition: transform 0.3s;">
      <div style="display: flex; align-items: center; gap: 8px; padding: 20px; border-bottom: 1px solid var(--border-color); background: rgba(245, 158, 11, 0.1);">
        <i class="fas fa-exclamation-triangle" style="color: var(--warning);"></i>
        <h3 style="margin: 0; font-size: 1.125rem; color: var(--gray-900);">Restore Database</h3>
      </div>
      <div style="padding: 20px;">
        <p style="margin: 0 0 12px 0; color: var(--text-secondary);">Are you sure you want to restore from this backup?</p>
        <p style="margin: 0 0 12px 0; color: var(--text-secondary);"><strong>Warning:</strong> This will replace your current database. Your current database will be backed up first.</p>
        <div id="restoreBackupName" style="background: var(--bg-secondary); padding: 12px; border-radius: 4px; font-family: monospace; font-size: 0.875rem;"></div>
      </div>
      <div style="display: flex; gap: 12px; justify-content: flex-end; padding: 24px; border-top: 1px solid var(--border-color); background: var(--bg-secondary);">
        <button data-action="close-modal" class="modal-btn-cancel">Cancel</button>
        <button id="confirmRestoreBtn" class="modal-btn-primary modal-btn-warning">
          <i class="fas fa-undo"></i> Restore Database
        </button>
      </div>
    </div>
  </div>

  <!-- Delete Modal -->
  <div id="deleteModal" class="modal-overlay" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; opacity: 0; visibility: hidden; transition: all 0.3s;">
    <div style="background: white; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); width: 100%; max-width: 480px; overflow: hidden; transform: scale(0.9); transition: transform 0.3s;">
      <div style="display: flex; align-items: center; gap: 8px; padding: 20px; border-bottom: 1px solid var(--border-color); background: rgba(239, 68, 68, 0.1);">
        <i class="fas fa-exclamation-circle" style="color: var(--danger);"></i>
        <h3 style="margin: 0; font-size: 1.125rem; color: var(--gray-900);">Delete Backup</h3>
      </div>
      <div style="padding: 20px;">
        <p style="margin: 0 0 12px 0; color: var(--text-secondary);">Are you sure you want to delete this backup?</p>
        <p style="margin: 0 0 12px 0; color: var(--text-secondary);"><strong>This action cannot be undone.</strong></p>
        <div id="deleteBackupName" style="background: var(--bg-secondary); padding: 12px; border-radius: 4px; font-family: monospace; font-size: 0.875rem;"></div>
      </div>
      <div style="display: flex; gap: 12px; justify-content: flex-end; padding: 24px; border-top: 1px solid var(--border-color); background: var(--bg-secondary);">
        <button data-action="close-modal" class="modal-btn-cancel">Cancel</button>
        <button id="confirmDeleteBtn" class="modal-btn-primary modal-btn-danger">
          <i class="fas fa-trash"></i> Delete Backup
        </button>
      </div>
    </div>
  </div>

  <style>
    /* Modal state styles */
    #restoreModal.active, #deleteModal.active {
      opacity: 1 !important;
      visibility: visible !important;
    }
    #restoreModal.active > div, #deleteModal.active > div {
      transform: scale(1) !important;
    }

    /* Backup action button styles */
    .backup-action-btn {
      padding: 8px 14px;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.8125rem;
      transition: all 0.2s ease;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .backup-btn-success {
      background-color: var(--success, #10b981);
    }

    .backup-btn-success:hover {
      background-color: #059669;
      box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
      transform: translateY(-1px);
    }

    .backup-btn-warning {
      background-color: var(--warning, #f59e0b);
    }

    .backup-btn-warning:hover {
      background-color: #d97706;
      box-shadow: 0 2px 8px rgba(217, 119, 6, 0.3);
      transform: translateY(-1px);
    }

    .backup-btn-danger {
      background-color: var(--danger, #ef4444);
    }

    .backup-btn-danger:hover {
      background-color: #dc2626;
      box-shadow: 0 2px 8px rgba(220, 38, 38, 0.4);
      transform: translateY(-1px);
    }

    /* Modal button styles */
    .modal-btn-cancel {
      padding: 12px 24px;
      background-color: #e5e7eb;
      color: #1f2937;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.9375rem;
      font-weight: 500;
      transition: all 0.2s ease;
    }

    .modal-btn-cancel:hover {
      background-color: #d1d5db;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .modal-btn-primary {
      padding: 12px 24px;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.9375rem;
      font-weight: 600;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .modal-btn-warning {
      background-color: var(--warning, #f59e0b);
    }

    .modal-btn-warning:hover {
      background-color: #d97706;
      box-shadow: 0 4px 12px rgba(217, 119, 6, 0.4);
    }

    .modal-btn-danger {
      background-color: var(--danger, #ef4444);
    }

    .modal-btn-danger:hover {
      background-color: #dc2626;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
    }
  </style>

  <!-- Notification -->
  <div id="notification" class="notification"></div>

  <script src="/js/mobile-nav.js"></script>
  <script src="/js/admin-backups.js"></script>
</body>
</html>
